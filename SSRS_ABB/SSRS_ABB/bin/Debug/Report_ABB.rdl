  <DataSets>
    <DataSet Name="AAB_Aeroportet">
      <Query>
        <DataSourceName>ABB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Aeroporti_abb">
            <Value>=Parameters!Aeroporti_abb.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Fluturimi_abb">
            <Value>=Parameters!Fluturimi_abb.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT Aeroportet_abb.id_abb, Aeroportet_abb.Aeroporti_abb, Aeroportet_abb.LinjaAjrore_abb, Aeroportet_abb.CmimiBiletes_abb,
Fluturimet_abb.Fluturimi_abb
FROM Aeroportet_abb
LEFT OUTER JOIN  Fluturimet_abb ON Aeroportet_abb.idFluturimi_abb = Fluturimet_abb.idFluturimi_abb 
WHERE  Aeroportet_abb.Aeroporti_abb IN (@Aeroporti_abb) OR Fluturimet_abb.Fluturimi_abb IN (@Fluturimi_abb);</CommandText>
      </Query>
      <Fields>
        <Field Name="id_abb">
          <DataField>id_abb</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Aeroporti_abb">
