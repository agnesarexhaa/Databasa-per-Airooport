          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Fluturimi_abb">
          <DataField>Fluturimi_abb</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
